<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Login Fragment -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.mavi.ui.fragments.LoginFragment"
        android:label="@string/login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
        <action
            android:id="@+id/action_loginFragment_to_chatListFragment"
            app:destination="@id/chatListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Register Fragment -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.mavi.ui.fragments.RegisterFragment"
        android:label="@string/register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Chat List Fragment -->
    <fragment
        android:id="@+id/chatListFragment"
        android:name="com.mavi.ui.fragments.ChatListFragment"
        android:label="@string/conversations"
        tools:layout="@layout/fragment_chat_list">
        <action
            android:id="@+id/action_chatListFragment_to_chatDetailFragment"
            app:destination="@id/chatDetailFragment" />
    </fragment>

    <!-- Chat Detail Fragment -->
    <fragment
        android:id="@+id/chatDetailFragment"
        android:name="com.mavi.ui.fragments.ChatDetailFragment"
        android:label="@string/messages"
        tools:layout="@layout/fragment_chat_detail">
        <argument
            android:name="user_id"
            app:argType="integer" />
        <argument
            android:name="username"
            app:argType="string" />
        <action
            android:id="@+id/action_chatDetailFragment_to_callFragment"
            app:destination="@id/callFragment" />
    </fragment>

    <!-- Call Fragment -->
    <fragment
        android:id="@+id/callFragment"
        android:name="com.mavi.ui.fragments.CallFragment"
        android:label="Call"
        tools:layout="@layout/fragment_call">
        <argument
            android:name="call_id"
            app:argType="string" />
        <argument
            android:name="caller_name"
            app:argType="string" />
        <argument
            android:name="caller_id"
            app:argType="integer" />
    </fragment>

</navigation>
